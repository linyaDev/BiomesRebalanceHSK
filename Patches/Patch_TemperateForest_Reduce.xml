<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- Reduce TemperateForest: trees and animals only -->
	<!-- Non-tree plants remain at HSK values -->
	<!-- Dense variant carries the original HSK values for everything -->

	<!-- animalDensity: 3.3 -> 1.61 -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/BiomeDef[defName="TemperateForest"]/animalDensity</xpath>
		<value><animalDensity>1.61</animalDensity></value>
	</Operation>

