<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- Reduce BorealForest: trees (-70%) and animals (-20%) only -->
	<!-- Non-tree plants remain at HSK values -->
	<!-- Dense variant carries the original HSK values for everything -->

	<!-- animalDensity: 2.5 -> 2.0 (-20%) -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/BiomeDef[defName="BorealForest"]/animalDensity</xpath>
		<value><animalDensity>2.0</animalDensity></value>
	</Operation>

	<!-- Trees (-70%) -->
	<!-- TreePine: 8.0 -> 2.4 -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/BiomeDef[defName="BorealForest"]/wildPlants/Plant_TreePine</xpath>
		<value><Plant_TreePine>2.4</Plant_TreePine></value>
	</Operation>
