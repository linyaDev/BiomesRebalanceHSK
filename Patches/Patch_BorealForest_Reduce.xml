<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- Reduce BorealForest: plantDensity halved, trees -70%, animals -20% -->
	<!-- Non-tree plants multiplied by 2.0 (=0.7/0.35) to compensate for plantDensity drop -->
	<!-- Dense variant carries the original HSK values -->

	<!-- animalDensity: 2.5 -> 2.0 (-20%) -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/BiomeDef[defName="BorealForest"]/animalDensity</xpath>
		<value><animalDensity>2.0</animalDensity></value>
	</Operation>

	<!-- plantDensity: 0.7 -> 0.525 -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/BiomeDef[defName="BorealForest"]/plantDensity</xpath>
		<value><plantDensity>0.525</plantDensity></value>
	</Operation>

