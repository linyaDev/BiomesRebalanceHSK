		<value>
			<lakeBeachTerrain>Sand</lakeBeachTerrain>
			<riverbankTerrain>Riverbank</riverbankTerrain>
			<riverbankSizeRange>6~8</riverbankSizeRange>
			<maxFishPopulation>540</maxFishPopulation>
			<fishTypes MayRequire="Ludeon.RimWorld.Odyssey">
				<freshwater_Common>
					<Fish_Salmon MayRequire="Ludeon.RimWorld.Odyssey">1</Fish_Salmon>
					<Fish_Bass MayRequire="Ludeon.RimWorld.Odyssey">1</Fish_Bass>
				</freshwater_Common>
				<freshwater_Uncommon>
					<Fish_Catfish MayRequire="Ludeon.RimWorld.Odyssey">1</Fish_Catfish>
				</freshwater_Uncommon>
				<saltwater_Common>
					<Fish_Salmon MayRequire="Ludeon.RimWorld.Odyssey">1</Fish_Salmon>
					<Fish_Bluefish MayRequire="Ludeon.RimWorld.Odyssey">1</Fish_Bluefish>
				</saltwater_Common>
				<saltwater_Uncommon>
